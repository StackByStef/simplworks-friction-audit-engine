# ── Website (Next.js) ──────────────────────────────────────────────
# Where the n8n engine listens, and the shared secret it requires.
N8N_AUDIT_WEBHOOK_URL=https://your-n8n-instance/webhook/friction-audit
N8N_AUDIT_WEBHOOK_SECRET=generate-a-long-random-string

# Lead capture + notification (the website route).
SUPABASE_URL=
SUPABASE_ANON_KEY=
RESEND_API_KEY=

# ── n8n (set these as CREDENTIALS inside n8n, not as repo env) ──────
# Supabase service_role key      -> Supabase credential
# OpenAI API key                 -> OpenAI credential
# Anthropic API key              -> Anthropic credential
# Resend API key                 -> Header Auth: Authorization = "Bearer re_..."
# Cloudflare Browser Rendering   -> Header Auth: Authorization = "Bearer <CF token>"
# Google PageSpeed API key       -> Query Auth: name = "key"
# Slack bot token (chat:write)   -> Slack credential
# Webhook shared secret          -> Header Auth: name = "x-audit-secret" (must match N8N_AUDIT_WEBHOOK_SECRET)
